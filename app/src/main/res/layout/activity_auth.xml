<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout android:id="@+id/clAuthParent"
                                             android:layout_width="match_parent"
                                             android:layout_height="match_parent"
                                             tools:context=".activity.Auth"
                                             xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             xmlns:tools="http://schemas.android.com/tools">

    <android.support.constraint.ConstraintLayout android:id="@+id/clAuthDialog"
                                                 android:layout_width="match_parent"
                                                 android:layout_height="wrap_content"
                                                 android:layout_marginStart="@dimen/_16dp"
                                                 android:layout_marginEnd="@dimen/_16dp"
                                                 android:layout_marginTop="@dimen/_16dp"
                                                 app:layout_constraintTop_toTopOf="parent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent">

        <android.support.v7.widget.CardView android:id="@+id/cvAuthDialog"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_16dp"
                                            android:layout_marginTop="@dimen/_16dp"
                                            android:layout_marginBottom="@dimen/_16dp"
                                            android:layout_marginEnd="@dimen/_16dp"
                                            app:cardCornerRadius="@dimen/_8dp"
                                            app:cardElevation="@dimen/_6dp"
                                            app:layout_constraintTop_toTopOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintBottom_toBottomOf="parent">

            <android.support.constraint.ConstraintLayout android:layout_width="match_parent"
                                                         android:layout_height="match_parent"
                                                         android:layout_marginStart="@dimen/_16dp"
                                                         android:layout_marginEnd="@dimen/_16dp"
                                                         android:layout_marginTop="@dimen/_16dp"
                                                         android:layout_marginBottom="@dimen/_16dp"
                                                         app:layout_constraintTop_toTopOf="parent"
                                                         app:layout_constraintBottom_toBottomOf="parent"
                                                         app:layout_constraintStart_toStartOf="parent"
                                                         app:layout_constraintEnd_toEndOf="parent">

                <ImageView android:id="@+id/ivAuthLogo"
                           android:layout_width="@dimen/_72dp"
                           android:layout_height="@dimen/_72dp"
                           android:layout_marginTop="@dimen/_16dp"
                           android:contentDescription="@string/cd_app_logo"
                           app:layout_constraintTop_toTopOf="parent"
                           app:layout_constraintStart_toStartOf="parent"
                           app:layout_constraintEnd_toEndOf="parent"
                           app:layout_constraintBottom_toTopOf="@+id/ivAuthLogoTitle"/>

                <ImageView android:id="@+id/ivAuthLogoTitle"
                           android:layout_width="@dimen/_100dp"
                           android:layout_height="@dimen/_32dp"
                           android:layout_marginStart="@dimen/_16dp"
                           android:layout_marginEnd="@dimen/_16dp"
                           android:contentDescription="@string/cd_app_title"
                           app:layout_constraintTop_toBottomOf="@+id/ivAuthLogo"
                           app:layout_constraintStart_toStartOf="parent"
                           app:layout_constraintEnd_toEndOf="parent"/>

                <Button android:id="@+id/btnAuthSignIn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16dp"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintTop_toBottomOf="@+id/ivAuthLogoTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/btnAuthSignUp"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                <Button android:id="@+id/btnAuthSignUp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16dp"
                        app:layout_constraintHorizontal_bias="0.5"
                        app:layout_constraintTop_toBottomOf="@+id/ivAuthLogoTitle"
                        app:layout_constraintStart_toEndOf="@+id/btnAuthSignIn"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

            </android.support.constraint.ConstraintLayout>

        </android.support.v7.widget.CardView>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clAuthDialogSignIn"
                                                 android:layout_width="match_parent"
                                                 android:layout_height="wrap_content"
                                                 android:layout_marginStart="@dimen/_16dp"
                                                 android:layout_marginEnd="@dimen/_16dp"
                                                 app:layout_constraintEnd_toStartOf="parent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintTop_toBottomOf="parent">

        <android.support.v7.widget.CardView android:id="@+id/cvAuthDialogSignIn"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_16dp"
                                            android:layout_marginEnd="@dimen/_16dp"
                                            android:layout_marginBottom="@dimen/_8dp"
                                            app:cardCornerRadius="@dimen/_8dp"
                                            app:cardElevation="@dimen/_6dp"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintBottom_toBottomOf="parent"
                                            app:layout_constraintTop_toTopOf="parent">

            <android.support.constraint.ConstraintLayout android:layout_width="match_parent"
                                                         android:layout_height="wrap_content">

                <TextView android:id="@+id/tvAuthDialogSignIn"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="@dimen/_16dp"
                          android:layout_marginEnd="@dimen/_16dp"
                          android:layout_marginTop="@dimen/_16dp"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintTop_toTopOf="parent"/>

                <EditText android:id="@+id/etAuthDialogUsernameSignIn"
                          android:labelFor="@id/etAuthDialogUsernameSignIn"
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:inputType="textEmailAddress"
                          android:textSize="@dimen/_14sp"
                          android:ems="10"
                          android:maxLines="1"
                          tools:ignore="Autofill"
                          app:layout_constraintHorizontal_bias="0.5"
                          app:layout_constraintTop_toBottomOf="@+id/tvAuthDialogSignIn"
                          app:layout_constraintStart_toStartOf="@+id/etAuthDialogPasswordSignIn"
                          app:layout_constraintEnd_toEndOf="@+id/etAuthDialogPasswordSignIn"
                          app:layout_constraintBottom_toTopOf="@+id/etAuthDialogPasswordSignIn"/>

                <EditText android:id="@+id/etAuthDialogPasswordSignIn"
                          android:labelFor="@id/etAuthDialogPasswordSignIn"
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="@dimen/_48dp"
                          android:layout_marginEnd="@dimen/_48dp"
                          android:inputType="textPassword"
                          android:textSize="@dimen/_14sp"
                          android:ems="10"
                          android:maxLines="1"
                          tools:ignore="Autofill"
                          app:layout_constraintHorizontal_bias="0.5"
                          app:layout_constraintTop_toBottomOf="@+id/etAuthDialogUsernameSignIn"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintBottom_toTopOf="@+id/btnAuthDialogSignIn"/>

                <Button android:id="@+id/btnAuthDialogSignIn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16dp"
                        android:layout_marginStart="@dimen/_32dp"
                        android:layout_marginEnd="@dimen/_32dp"
                        android:layout_marginBottom="@dimen/_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/etAuthDialogPasswordSignIn"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

            </android.support.constraint.ConstraintLayout>

        </android.support.v7.widget.CardView>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clAuthDialogSignUp"
                                                 android:layout_width="match_parent"
                                                 android:layout_height="wrap_content"
                                                 android:layout_marginStart="@dimen/_16dp"
                                                 android:layout_marginEnd="@dimen/_16dp"
                                                 app:layout_constraintEnd_toEndOf="parent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintTop_toBottomOf="parent">

        <android.support.v7.widget.CardView android:id="@+id/cvAuthDialogSignUp"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_16dp"
                                            android:layout_marginEnd="@dimen/_16dp"
                                            android:layout_marginBottom="@dimen/_8dp"
                                            app:cardCornerRadius="@dimen/_8dp"
                                            app:cardElevation="@dimen/_6dp"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintBottom_toBottomOf="parent"
                                            app:layout_constraintTop_toTopOf="parent">

            <android.support.constraint.ConstraintLayout android:layout_width="match_parent"
                                                         android:layout_height="wrap_content">

                <TextView android:id="@+id/tvAuthDialogSignUp"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="@dimen/_16dp"
                          android:layout_marginEnd="@dimen/_16dp"
                          android:layout_marginTop="@dimen/_16dp"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintTop_toTopOf="parent"/>

                <EditText android:id="@+id/etAuthDialogUsernameSignUp"
                          android:labelFor="@id/etAuthDialogUsernameSignUp"
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:inputType="text"
                          android:textSize="@dimen/_14sp"
                          android:ems="10"
                          android:maxLines="1"
                          tools:ignore="Autofill"
                          app:layout_constraintHorizontal_bias="0.5"
                          app:layout_constraintTop_toBottomOf="@+id/tvAuthDialogSignUp"
                          app:layout_constraintEnd_toEndOf="@+id/etAuthDialogEmailSignUp"
                          app:layout_constraintStart_toStartOf="@+id/etAuthDialogEmailSignUp"
                          app:layout_constraintBottom_toTopOf="@+id/etAuthDialogEmailSignUp"/>

                <EditText android:id="@+id/etAuthDialogEmailSignUp"
                          android:labelFor="@id/etAuthDialogEmailSignUp"
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:inputType="textEmailAddress"
                          android:textSize="@dimen/_14sp"
                          android:ems="10"
                          android:maxLines="1"
                          tools:ignore="Autofill"
                          app:layout_constraintHorizontal_bias="0.5"
                          app:layout_constraintTop_toBottomOf="@+id/etAuthDialogUsernameSignUp"
                          app:layout_constraintStart_toStartOf="@+id/etAuthDialogPasswordSignUp"
                          app:layout_constraintEnd_toEndOf="@+id/etAuthDialogPasswordSignUp"
                          app:layout_constraintBottom_toTopOf="@+id/etAuthDialogPasswordSignUp"/>

                <EditText android:id="@+id/etAuthDialogPasswordSignUp"
                          android:labelFor="@id/etAuthDialogPasswordSignUp"
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="@dimen/_48dp"
                          android:layout_marginEnd="@dimen/_48dp"
                          android:inputType="textPassword"
                          android:textSize="@dimen/_14sp"
                          android:ems="10"
                          android:maxLines="1"
                          tools:ignore="Autofill"
                          app:layout_constraintHorizontal_bias="0.5"
                          app:layout_constraintTop_toBottomOf="@+id/etAuthDialogEmailSignUp"
                          app:layout_constraintEnd_toEndOf="parent"
                          app:layout_constraintStart_toStartOf="parent"
                          app:layout_constraintBottom_toTopOf="@+id/btnAuthDialogSignUp"/>

                <Button android:id="@+id/btnAuthDialogSignUp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16dp"
                        android:layout_marginStart="@dimen/_32dp"
                        android:layout_marginEnd="@dimen/_32dp"
                        android:layout_marginBottom="@dimen/_16dp"
                        app:layout_constraintTop_toBottomOf="@+id/etAuthDialogPasswordSignUp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

            </android.support.constraint.ConstraintLayout>

        </android.support.v7.widget.CardView>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>