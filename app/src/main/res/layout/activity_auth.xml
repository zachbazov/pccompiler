<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout android:id="@+id/clAuth"
                                             android:layout_width="match_parent"
                                             android:layout_height="wrap_content"
                                             tools:context=".activity.Auth"
                                             xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             xmlns:tools="http://schemas.android.com/tools">

    <ImageView android:id="@+id/ivAuthLogo"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginTop="@dimen/_16dp"
               android:contentDescription="@string/cd_app_logo"
               app:layout_constraintHorizontal_bias="0.5"
               app:layout_constraintHorizontal_chainStyle="packed"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintEnd_toStartOf="@+id/ivAuthLogoTitle"/>

    <ImageView android:id="@+id/ivAuthLogoTitle"
               android:layout_width="@dimen/_96dp"
               android:layout_height="@dimen/_32dp"
               android:layout_marginStart="@dimen/_8dp"
               android:contentDescription="@string/cd_app_title"
               app:layout_constraintHorizontal_bias="0.5"
               app:layout_constraintTop_toTopOf="@+id/ivAuthLogo"
               app:layout_constraintBottom_toBottomOf="@+id/ivAuthLogo"
               app:layout_constraintStart_toEndOf="@+id/ivAuthLogo"
               app:layout_constraintEnd_toEndOf="parent"/>

    <android.support.v7.widget.CardView android:id="@+id/cvFragAuthSignIn"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/_16dp"
                                        app:cardUseCompatPadding="true"
                                        app:layout_constraintTop_toBottomOf="@+id/ivAuthLogoTitle"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent">

        <android.support.constraint.ConstraintLayout android:id="@+id/clFragAuthSignIn"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     android:layout_marginStart="@dimen/_48dp"
                                                     android:layout_marginEnd="@dimen/_48dp">

            <EditText android:id="@+id/etAuthSignInUsername"
                      android:labelFor="@id/etAuthSignInUsername"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/_16dp"
                      android:inputType="textEmailAddress"
                      android:textSize="@dimen/_14sp"
                      android:ems="10"
                      android:maxLines="1"
                      tools:ignore="Autofill"
                      app:layout_constraintTop_toTopOf="parent"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"/>

            <EditText android:id="@+id/etAuthSignInPassword"
                      android:labelFor="@id/etAuthSignInPassword"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:inputType="textPassword"
                      android:textSize="@dimen/_14sp"
                      android:ems="10"
                      android:maxLines="1"
                      tools:ignore="Autofill"
                      app:layout_constraintTop_toBottomOf="@+id/etAuthSignInUsername"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintStart_toStartOf="parent"/>

            <Button android:id="@+id/btnAuthSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8dp"
                    app:layout_constraintTop_toBottomOf="@+id/etAuthSignInPassword"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

            <TextView android:id="@+id/tvAuthSignUp"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/_8dp"
                      android:layout_marginBottom="@dimen/_8dp"
                      app:layout_constraintTop_toBottomOf="@+id/btnAuthSignIn"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintBottom_toBottomOf="parent"/>

        </android.support.constraint.ConstraintLayout>

    </android.support.v7.widget.CardView>

    <android.support.v7.widget.CardView android:id="@+id/cvFragAuthSignUp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/_16dp"
                                        app:cardUseCompatPadding="true"
                                        app:layout_constraintTop_toBottomOf="@+id/ivAuthLogoTitle"
                                        app:layout_constraintStart_toEndOf="parent">

        <android.support.constraint.ConstraintLayout android:id="@+id/clFragAuthSignUp"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     android:layout_marginStart="@dimen/_48dp"
                                                     android:layout_marginEnd="@dimen/_48dp">

            <EditText android:id="@+id/etAuthSignUpUsername"
                      android:labelFor="@id/etAuthSignUpUsername"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/_16dp"
                      android:inputType="text"
                      android:textSize="@dimen/_14sp"
                      android:ems="10"
                      android:maxLines="1"
                      tools:ignore="Autofill"
                      app:layout_constraintTop_toTopOf="parent"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"/>

            <EditText android:id="@+id/etAuthSignUpEmail"
                      android:labelFor="@id/etAuthSignUpEmail"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:inputType="textEmailAddress"
                      android:textSize="@dimen/_14sp"
                      android:ems="10"
                      android:maxLines="1"
                      tools:ignore="Autofill"
                      app:layout_constraintTop_toBottomOf="@+id/etAuthSignUpUsername"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"/>

            <EditText android:id="@+id/etAuthSignUpPassword"
                      android:labelFor="@id/etAuthSignUpPassword"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:inputType="textPassword"
                      android:textSize="@dimen/_14sp"
                      android:ems="10"
                      android:maxLines="1"
                      tools:ignore="Autofill"
                      app:layout_constraintTop_toBottomOf="@+id/etAuthSignUpEmail"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintStart_toStartOf="parent"/>

            <Button android:id="@+id/btnAuthSignUp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8dp"
                    app:layout_constraintTop_toBottomOf="@+id/etAuthSignUpPassword"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

            <TextView android:id="@+id/tvAuthSignIn"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/_8dp"
                      android:layout_marginBottom="@dimen/_8dp"
                      app:layout_constraintTop_toBottomOf="@+id/btnAuthSignUp"
                      app:layout_constraintBottom_toBottomOf="parent"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"/>

        </android.support.constraint.ConstraintLayout>

    </android.support.v7.widget.CardView>

</android.support.constraint.ConstraintLayout>