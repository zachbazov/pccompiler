<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout android:id="@+id/clWorkspaceParent"
                                             android:layout_width="match_parent"
                                             android:layout_height="wrap_content"
                                             tools:context=".activity.Workspace"
                                             xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             xmlns:tools="http://schemas.android.com/tools">

    <android.support.v7.widget.CardView android:id="@+id/cvTabParent"
                                        android:layout_width="0dp"
                                        android:layout_height="@dimen/_60dp"
                                        app:cardElevation="@dimen/_6dp"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toTopOf="parent">

        <android.support.constraint.ConstraintLayout android:id="@+id/clTabParent"
                                                     android:layout_width="match_parent"
                                                     android:layout_height="match_parent">

            <ImageView android:id="@+id/ivTracker"
                       android:layout_width="wrap_content"
                       android:layout_height="@dimen/_3dp"
                       android:contentDescription="@string/cd_tab_tracker"
                       android:src="@color/colorPrimary"
                       android:layout_gravity="bottom"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout android:id="@+id/llTab"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="horizontal"
                          android:divider="@drawable/div_primary"
                          android:showDividers="middle"
                          android:weightSum="2"
                          android:baselineAligned="true">

                <android.support.constraint.ConstraintLayout android:id="@+id/clTabWorkspace"
                                                             android:layout_width="match_parent"
                                                             android:layout_height="@dimen/_60dp"
                                                             android:layout_weight="1">

                    <ImageView android:id="@+id/ivTabWorkspace"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:contentDescription="@string/cd_workspace"
                               app:layout_constraintBottom_toBottomOf="parent"
                               app:layout_constraintEnd_toEndOf="parent"
                               app:layout_constraintStart_toStartOf="parent"
                               app:layout_constraintTop_toTopOf="parent"/>

                </android.support.constraint.ConstraintLayout>

                <android.support.constraint.ConstraintLayout android:id="@+id/clTabCart"
                                                             android:layout_width="match_parent"
                                                             android:layout_height="@dimen/_60dp"
                                                             android:layout_weight="1">

                    <ImageView
                            android:id="@+id/ivTabCart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/cd_cart"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                </android.support.constraint.ConstraintLayout>

            </LinearLayout>

        </android.support.constraint.ConstraintLayout>

    </android.support.v7.widget.CardView>

    <android.support.constraint.ConstraintLayout android:id="@+id/clDashboard"
                                                 android:layout_width="match_parent"
                                                 android:layout_height="wrap_content"
                                                 android:layout_marginTop="@dimen/_16dp"
                                                 app:layout_constraintTop_toBottomOf="@+id/cvTabParent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent">

        <android.support.constraint.ConstraintLayout android:id="@+id/clUser"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     android:layout_marginEnd="@dimen/_16dp"
                                                     app:layout_constraintEnd_toEndOf="parent"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent">
            <ImageView android:id="@+id/ivUser"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_user"
                       android:layout_marginStart="@dimen/_16dp"
                       android:layout_marginEnd="@dimen/_16dp"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintEnd_toEndOf="parent"
                       app:layout_constraintTop_toTopOf="parent"/>

            <TextView android:id="@+id/tvUser"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textAlignment="center"
                      app:layout_constraintTop_toBottomOf="@+id/ivUser"
                      app:layout_constraintEnd_toEndOf="@+id/ivUser"
                      app:layout_constraintStart_toStartOf="@+id/ivUser"/>

        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout android:id="@+id/clActionBar"
                                                     android:layout_width="0dp"
                                                     android:layout_height="match_parent"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent"
                                                     app:layout_constraintStart_toStartOf="parent"
                                                     app:layout_constraintEnd_toStartOf="@+id/clUser"
        >
            <ImageView android:id="@+id/ivRemove"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_remove"
                       android:layout_marginBottom="@dimen/_16dp"
                       app:layout_constraintHorizontal_bias="0.5"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintEnd_toEndOf="parent"
                       app:layout_constraintStart_toEndOf="@+id/ivEdit"/>

            <TextView android:id="@+id/tvRemove"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      app:layout_constraintTop_toBottomOf="@+id/ivRemove"
                      app:layout_constraintEnd_toEndOf="@+id/ivRemove"
                      app:layout_constraintStart_toStartOf="@+id/ivRemove"
                      app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView android:id="@+id/ivEdit"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_edit"
                       android:layout_marginBottom="@dimen/_16dp"
                       android:layout_marginEnd="@dimen/_32dp"
                       app:layout_constraintHorizontal_bias="0.5"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintEnd_toStartOf="@+id/ivRemove"
                       app:layout_constraintStart_toEndOf="@+id/ivAdd"/>

            <TextView android:id="@+id/tvEdit"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      app:layout_constraintTop_toBottomOf="@+id/ivEdit"
                      app:layout_constraintStart_toStartOf="@+id/ivEdit"
                      app:layout_constraintEnd_toEndOf="@+id/ivEdit"
                      app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView android:id="@+id/ivAdd"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_add"
                       android:layout_marginEnd="@dimen/_32dp"
                       android:layout_marginBottom="@dimen/_16dp"
                       app:layout_constraintHorizontal_bias="0.5"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintStart_toEndOf="@+id/ivMenu"
                       app:layout_constraintEnd_toStartOf="@+id/ivEdit"/>

            <TextView android:id="@+id/tvAdd"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      app:layout_constraintTop_toBottomOf="@+id/ivAdd"
                      app:layout_constraintEnd_toEndOf="@+id/ivAdd"
                      app:layout_constraintStart_toStartOf="@+id/ivAdd"
                      app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView android:id="@+id/ivMenu"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_menu"
                       android:layout_marginEnd="@dimen/_32dp"
                       android:layout_marginBottom="@dimen/_16dp"
                       app:layout_constraintHorizontal_bias="0.5"
                       app:layout_constraintHorizontal_chainStyle="packed"
                       app:layout_constraintEnd_toStartOf="@+id/ivAdd"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintStart_toStartOf="parent"/>

            <TextView android:id="@+id/tvMenu"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textAlignment="center"
                      app:layout_constraintTop_toBottomOf="@+id/ivMenu"
                      app:layout_constraintEnd_toEndOf="@+id/ivMenu"
                      app:layout_constraintStart_toStartOf="@+id/ivMenu"
                      app:layout_constraintBottom_toBottomOf="parent"/>

        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout android:id="@+id/clControlPanel"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="match_parent"
                                                     app:layout_constraintBottom_toBottomOf="parent"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintStart_toEndOf="parent">

            <ImageView android:id="@+id/ivSettings"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_settings"
                       android:layout_marginBottom="@dimen/_16dp"
                       app:layout_constraintHorizontal_bias="0.5"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintEnd_toStartOf="@+id/ivLogout"/>

            <TextView android:id="@+id/tvSettings"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      app:layout_constraintTop_toBottomOf="@+id/ivSettings"
                      app:layout_constraintStart_toStartOf="@+id/ivSettings"
                      app:layout_constraintEnd_toEndOf="@+id/ivSettings"
                      app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView android:id="@+id/ivLogout"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_logout"
                       android:layout_marginStart="@dimen/_32dp"
                       android:layout_marginBottom="@dimen/_16dp"
                       app:layout_constraintHorizontal_bias="0.5"
                       app:layout_constraintStart_toEndOf="@+id/ivSettings"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintEnd_toEndOf="parent"/>

            <TextView android:id="@+id/tvLogout"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      app:layout_constraintStart_toStartOf="@+id/ivLogout"
                      app:layout_constraintEnd_toEndOf="@+id/ivLogout"
                      app:layout_constraintTop_toBottomOf="@+id/ivLogout"
                      app:layout_constraintBottom_toBottomOf="parent"/>

        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>