<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             xmlns:tools="http://schemas.android.com/tools"
                                             android:id="@+id/clWorkspaceParent"
                                             android:layout_width="match_parent"
                                             android:layout_height="match_parent"
                                             tools:context=".activity.Workspace">

    <android.support.v7.widget.CardView android:id="@+id/cvTabParent"
                                        android:layout_width="0dp"
                                        android:layout_height="@dimen/_60dp"
                                        app:cardElevation="@dimen/_6dp"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toTopOf="parent">

        <android.support.constraint.ConstraintLayout android:id="@+id/clTabParent"
                                                     android:layout_width="match_parent"
                                                     android:layout_height="match_parent">

            <ImageView android:id="@+id/ivTracker"
                       android:layout_width="wrap_content"
                       android:layout_height="@dimen/_3dp"
                       android:contentDescription="@string/cd_tab_tracker"
                       android:src="@color/colorPrimary"
                       android:layout_gravity="bottom"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout android:id="@+id/llTab"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="horizontal"
                          android:divider="@drawable/div_primary"
                          android:showDividers="middle"
                          android:weightSum="2"
                          android:baselineAligned="true">

                <android.support.constraint.ConstraintLayout android:id="@+id/clTabWorkspace"
                                                             android:layout_width="match_parent"
                                                             android:layout_height="@dimen/_60dp"
                                                             android:layout_weight="1">

                    <ImageView android:id="@+id/ivTabWorkspace"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:contentDescription="@string/cd_workspace"
                               app:layout_constraintBottom_toBottomOf="parent"
                               app:layout_constraintEnd_toEndOf="parent"
                               app:layout_constraintStart_toStartOf="parent"
                               app:layout_constraintTop_toTopOf="parent"/>

                </android.support.constraint.ConstraintLayout>

                <android.support.constraint.ConstraintLayout android:id="@+id/clTabCart"
                                                             android:layout_width="match_parent"
                                                             android:layout_height="@dimen/_60dp"
                                                             android:layout_weight="1">

                    <ImageView
                            android:id="@+id/ivTabCart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/cd_cart"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                </android.support.constraint.ConstraintLayout>

            </LinearLayout>

        </android.support.constraint.ConstraintLayout>

    </android.support.v7.widget.CardView>

    <android.support.constraint.ConstraintLayout android:id="@+id/clDashboard"
                                                 android:layout_width="0dp"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toBottomOf="@+id/cvTabParent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent"
                                                 android:layout_marginTop="8dp">

        <android.support.constraint.ConstraintLayout android:id="@+id/clActionBar"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent"
                                                     app:layout_constraintStart_toStartOf="parent"
                                                     app:layout_constraintEnd_toEndOf="parent">

            <android.support.v7.widget.RecyclerView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                    tools:listitem="@layout/item_action_bar"
                    app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                    android:orientation="horizontal"
                    android:id="@+id/rvActionBar"
                    app:layout_constraintStart_toStartOf="parent"/>
        </android.support.constraint.ConstraintLayout>
        <android.support.constraint.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:id="@+id/clCartBar"
                app:layout_constraintEnd_toStartOf="parent">

            <TextView
                    android:text="TextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:id="@+id/textView"
                    app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragWorkspaceParent"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toBottomOf="@+id/clDashboard"
                                                 app:layout_constraintEnd_toEndOf="parent"
                                                 app:layout_constraintStart_toStartOf="parent"
    >

        <android.support.constraint.ConstraintLayout android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     android:id="@+id/clFragWorkspace"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent"
                                                     app:layout_constraintStart_toStartOf="parent"
                                                     app:layout_constraintEnd_toEndOf="parent">

            <android.support.v7.widget.CardView android:id="@+id/cvCompilationBar"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                app:layout_constraintTop_toTopOf="parent"
                                                app:layout_constraintStart_toStartOf="parent"
                                                app:layout_constraintEnd_toEndOf="parent"
                                                app:layout_constraintBottom_toBottomOf="parent"
                                                app:cardBackgroundColor="@color/colorCloud">

                <android.support.constraint.ConstraintLayout android:id="@+id/clCompilationBar"
                                                             android:layout_width="wrap_content"
                                                             android:layout_height="wrap_content">

                    <android.support.v7.widget.RecyclerView android:id="@+id/rvCompilation"
                                                            android:layout_width="wrap_content"
                                                            android:layout_height="wrap_content"
                                                            android:orientation="horizontal"
                                                            tools:listitem="@layout/item_compilation_bar"
                                                            app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                                                            app:layout_constraintStart_toStartOf="parent"
                                                            app:layout_constraintEnd_toEndOf="parent"
                                                            app:layout_constraintTop_toTopOf="parent"
                                                            app:layout_constraintBottom_toBottomOf="parent"/>

                </android.support.constraint.ConstraintLayout>

            </android.support.v7.widget.CardView>

        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>
    <android.support.constraint.ConstraintLayout android:id="@+id/clFragCartParent"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toBottomOf="@+id/clDashboard"
                                                 app:layout_constraintStart_toStartOf="parent"
    >

        <android.support.constraint.ConstraintLayout android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     android:id="@+id/clFragCart"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent"
                                                     app:layout_constraintStart_toStartOf="parent"
                                                     app:layout_constraintEnd_toEndOf="parent">

            <android.support.v7.widget.CardView android:id="@+id/cvCart"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                app:cardBackgroundColor="@color/colorCloud"
                                                app:layout_constraintTop_toTopOf="parent"
                                                app:layout_constraintStart_toStartOf="parent"
                                                app:layout_constraintEnd_toEndOf="parent"
                                                app:layout_constraintBottom_toBottomOf="parent">

                <android.support.constraint.ConstraintLayout android:id="@+id/clCart"
                                                             android:layout_width="wrap_content"
                                                             android:layout_height="wrap_content">

                    <android.support.v7.widget.RecyclerView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/rvCart"
                            tools:listitem="@layout/item_compilation_bar"
                            app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

                </android.support.constraint.ConstraintLayout>

            </android.support.v7.widget.CardView>

        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>
    <android.support.constraint.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/clFragControlPanelParent"
            app:layout_constraintTop_toTopOf="@+id/clFragWorkspaceParent"
            app:layout_constraintEnd_toStartOf="parent">

        <android.support.constraint.ConstraintLayout android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintStart_toStartOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent"
                                                     app:layout_constraintEnd_toEndOf="parent"
                                                     android:id="@+id/clFragControlPanel">

            <android.support.v7.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:id="@+id/cvControlPanel"
                    app:cardUseCompatPadding="true"
                    app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent">
                <android.support.constraint.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:id="@+id/clControlPanel">

                    <ImageView android:id="@+id/ivSettings"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:contentDescription="@string/cd_settings"
                               app:layout_constraintTop_toTopOf="parent"
                               app:layout_constraintBottom_toTopOf="@+id/dvControlPanel"
                               app:layout_constraintStart_toStartOf="parent"
                               android:layout_marginStart="16dp" android:layout_marginBottom="16dp"
                               android:layout_marginTop="16dp"/>
                    <TextView android:id="@+id/tvSettings"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              app:layout_constraintTop_toTopOf="@+id/ivSettings"
                              app:layout_constraintBottom_toBottomOf="@+id/ivSettings"
                              app:layout_constraintStart_toEndOf="@+id/ivSettings" android:layout_marginStart="8dp"
                    />
                    <ImageView android:id="@+id/ivLogout"
                               android:layout_width="wrap_content"
                               android:layout_height="wrap_content"
                               android:contentDescription="@string/cd_logout"
                               app:layout_constraintBottom_toBottomOf="parent"
                               app:layout_constraintTop_toBottomOf="@+id/dvControlPanel"
                               app:layout_constraintStart_toStartOf="parent"
                               android:layout_marginStart="16dp" android:layout_marginTop="16dp"
                               android:layout_marginBottom="16dp"/>
                    <TextView android:id="@+id/tvLogout"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              app:layout_constraintStart_toEndOf="@+id/ivLogout"
                              android:layout_marginStart="8dp"
                              app:layout_constraintTop_toTopOf="@+id/ivLogout"
                              app:layout_constraintBottom_toBottomOf="@+id/ivLogout"
                    />
                    <View
                            android:id="@+id/dvControlPanel"
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:background="?android:attr/listDivider"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_marginStart="8dp" app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="8dp" app:layout_constraintTop_toBottomOf="@+id/ivSettings"
                            app:layout_constraintBottom_toTopOf="@+id/ivLogout"
                            app:layout_constraintHorizontal_bias="0.5"/>
                </android.support.constraint.ConstraintLayout>
            </android.support.v7.widget.CardView>
        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>
