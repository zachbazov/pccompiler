<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout android:id="@+id/clWorkspaceParent"
                                             android:layout_width="match_parent"
                                             android:layout_height="match_parent"
                                             tools:context=".activity.Workspace"
                                             xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             xmlns:tools="http://schemas.android.com/tools">

    <android.support.v7.widget.CardView android:id="@+id/cvFragTabBar"
                                        android:layout_width="wrap_content"
                                        android:layout_height="@dimen/_60dp"
                                        app:cardElevation="@dimen/_6dp"
                                        app:layout_constraintEnd_toEndOf="parent"
                                        app:layout_constraintStart_toStartOf="parent"
                                        app:layout_constraintTop_toTopOf="parent"
                                        app:layout_constraintBottom_toTopOf="@+id/clFragActionBar">

        <android.support.constraint.ConstraintLayout android:id="@+id/clFragTabBar"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="wrap_content">

            <ImageView android:id="@+id/ivTracker"
                       android:layout_width="wrap_content"
                       android:layout_height="@dimen/_3dp"
                       android:src="@color/colorPrimary"
                       android:contentDescription="@string/cd_tab_tracker"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintStart_toStartOf="parent"/>

            <android.support.v7.widget.RecyclerView android:id="@+id/rvTabBar"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    tools:listitem="@layout/item_tab_bar"
                                                    app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                                                    android:orientation="horizontal"
                                                    app:layout_constraintStart_toStartOf="parent"
                                                    app:layout_constraintEnd_toEndOf="parent"
                                                    app:layout_constraintTop_toTopOf="parent"
                                                    app:layout_constraintBottom_toBottomOf="parent"/>

        </android.support.constraint.ConstraintLayout>

    </android.support.v7.widget.CardView>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragActionBar"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent"
                                                 app:layout_constraintTop_toBottomOf="@+id/cvFragTabBar">

        <android.support.v7.widget.CardView android:id="@+id/cvFragActionBar"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginBottom="@dimen/_8dp"
                                            app:layout_constraintTop_toTopOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintBottom_toBottomOf="parent">

            <android.support.v7.widget.RecyclerView android:id="@+id/rvActionBar"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:orientation="horizontal"
                                                    tools:listitem="@layout/item_action_bar"
                                                    app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                                                    app:layout_constraintTop_toTopOf="parent"
                                                    app:layout_constraintEnd_toEndOf="parent"
                                                    app:layout_constraintBottom_toBottomOf="parent"
                                                    app:layout_constraintStart_toStartOf="parent"/>

        </android.support.v7.widget.CardView>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragControlBar"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toBottomOf="@+id/cvFragTabBar"
                                                 app:layout_constraintEnd_toStartOf="parent">

        <android.support.v7.widget.CardView android:id="@+id/cvFragControlBar"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginBottom="@dimen/_8dp"
                                            app:layout_constraintTop_toTopOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintEnd_toEndOf="parent"
                                            app:layout_constraintBottom_toBottomOf="parent">

            <android.support.v7.widget.RecyclerView android:id="@+id/rvControlBar"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    tools:listitem="@layout/item_control_bar"
                                                    app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                                                    android:orientation="horizontal"
                                                    app:layout_constraintTop_toTopOf="parent"
                                                    app:layout_constraintStart_toStartOf="parent"
                                                    app:layout_constraintBottom_toBottomOf="parent"
                                                    app:layout_constraintEnd_toEndOf="parent"/>

        </android.support.v7.widget.CardView>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragTitle"
                                                 android:layout_width="0dp"
                                                 android:layout_height="wrap_content"
                                                 android:layout_marginTop="@dimen/_8dp"
                                                 app:layout_constraintTop_toBottomOf="@+id/clFragActionBar"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent">

        <TextView android:id="@+id/tvWorkspaceTitle"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="@dimen/_16dp"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/tvCartTitle"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintStart_toEndOf="parent"/>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragWorkspace"
                                                 android:layout_width="0dp"
                                                 android:layout_height="0dp"
                                                 android:layout_marginTop="@dimen/_8dp"
                                                 app:layout_constraintTop_toBottomOf="@+id/clFragTitle"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent">

        <android.support.v7.widget.RecyclerView android:id="@+id/rvCompilationBar"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:orientation="horizontal"
                                                tools:listitem="@layout/item_compilation_bar"
                                                app:layout_constraintTop_toTopOf="parent"
                                                app:layout_constraintStart_toStartOf="parent"
                                                app:layout_constraintEnd_toEndOf="parent"
                                                app:layout_constraintBottom_toBottomOf="parent"/>

        <android.support.constraint.ConstraintLayout android:id="@+id/clBackward"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="0dp"
                                                     android:layout_marginTop="@dimen/_4dp"
                                                     android:layout_marginBottom="@dimen/_4dp"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintStart_toStartOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent">

            <ImageView android:id="@+id/ivBackward"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:contentDescription="@string/cd_backward"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintTop_toTopOf="parent"
                       app:layout_constraintStart_toStartOf="parent"
                       app:layout_constraintEnd_toEndOf="parent"/>

        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.ConstraintLayout android:id="@+id/clForward"
                                                     android:layout_width="wrap_content"
                                                     android:layout_height="0dp"
                                                     android:layout_marginTop="@dimen/_4dp"
                                                     android:layout_marginBottom="@dimen/_4dp"
                                                     app:layout_constraintEnd_toEndOf="parent"
                                                     app:layout_constraintTop_toTopOf="parent"
                                                     app:layout_constraintBottom_toBottomOf="parent">

            <ImageView android:id="@+id/ivForward"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:scaleX="-1"
                       android:contentDescription="@string/cd_forward"
                       app:layout_constraintEnd_toEndOf="parent"
                       app:layout_constraintBottom_toBottomOf="parent"
                       app:layout_constraintTop_toTopOf="parent"/>

        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragCart"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="0dp"
                                                 android:layout_marginTop="@dimen/_8dp"
                                                 app:layout_constraintTop_toBottomOf="@+id/clFragTitle"
                                                 app:layout_constraintBottom_toBottomOf="parent"
                                                 app:layout_constraintVertical_bias="0.0"
                                                 app:layout_constraintStart_toEndOf="parent"
    >

        <android.support.v7.widget.RecyclerView android:id="@+id/rvCartBar"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                tools:listitem="@layout/item_cart_bar"
                                                app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                                                app:layout_constraintStart_toStartOf="parent"
                                                app:layout_constraintEnd_toEndOf="parent"
                                                app:layout_constraintTop_toTopOf="parent"
        />

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout android:id="@+id/clFragControlPanel"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toBottomOf="@+id/clFragTitle"
                                                 app:layout_constraintEnd_toStartOf="parent">

        <android.support.v7.widget.CardView android:id="@+id/cvControlPanel"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            app:cardUseCompatPadding="true"
                                            app:layout_constraintTop_toTopOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            app:layout_constraintBottom_toBottomOf="parent"
                                            app:layout_constraintEnd_toEndOf="parent">

            <android.support.v7.widget.RecyclerView android:id="@+id/rvControlPanel"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    app:layoutManager="android.support.v7.widget.LinearLayoutManager"
                                                    tools:listitem="@layout/item_control_panel"
                                                    app:layout_constraintStart_toStartOf="parent"
                                                    app:layout_constraintBottom_toBottomOf="parent"
                                                    app:layout_constraintEnd_toEndOf="parent"
                                                    app:layout_constraintTop_toBottomOf="parent"/>

        </android.support.v7.widget.CardView>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>