<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView android:id="@+id/cvPrelimParent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:cardUseCompatPadding="true"
                                    xmlns:android="http://schemas.android.com/apk/res/android"
                                    xmlns:app="http://schemas.android.com/apk/res-auto"
                                    xmlns:tools="http://schemas.android.com/tools">

    <android.support.constraint.ConstraintLayout android:id="@+id/clPrelim"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content">

        <ImageView android:id="@+id/ivPrelim"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginEnd="@dimen/_8dp"
                   android:layout_marginTop="@dimen/_8dp"
                   android:contentDescription="@string/cd_close"
                   app:layout_constraintEnd_toEndOf="parent"
                   app:layout_constraintTop_toTopOf="parent"/>

        <TextView android:id="@+id/tvPrelim"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintStart_toStartOf="parent"/>

        <EditText android:id="@+id/etPrelim"
                  android:labelFor="@id/etPrelim"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_16dp"
                  android:layout_marginStart="@dimen/_32dp"
                  android:layout_marginEnd="@dimen/_32dp"
                  android:inputType="text"
                  android:ems="10"
                  android:singleLine="true"
                  android:textSize="14sp"
                  tools:ignore="Autofill"
                  app:layout_constraintTop_toBottomOf="@+id/tvPrelim"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"/>

        <Button android:id="@+id/btnPrelim"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8dp"
                android:layout_marginBottom="@dimen/_8dp"
                android:layout_marginEnd="@dimen/_16dp"
                android:layout_marginStart="@dimen/_16dp"
                app:layout_constraintTop_toBottomOf="@+id/etPrelim"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>