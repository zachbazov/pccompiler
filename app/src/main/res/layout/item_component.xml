<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:tools="http://schemas.android.com/tools"
                                             xmlns:app="http://schemas.android.com/apk/res-auto"
                                             android:id="@+id/clComponentParent"
                                             android:layout_width="match_parent"
                                             android:layout_height="wrap_content"
                                             tools:context=".activity.Compile">

    <android.support.constraint.ConstraintLayout android:id="@+id/clComponent"
                                                 android:layout_width="0dp"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toTopOf="parent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintBottom_toBottomOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent">

        <ImageView android:id="@+id/ivComponent"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginStart="16dp"
                   android:layout_marginTop="8dp"
                   android:contentDescription="@string/cd_compilation"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toTopOf="parent"
                   android:layout_marginBottom="8dp"
                   app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/tvComponent"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="16dp"
                  app:layout_constraintStart_toEndOf="@+id/ivComponent"
                  android:layout_marginTop="8dp"
                  app:layout_constraintTop_toTopOf="parent"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:id="@+id/tvComponentParamA"
                app:layout_constraintTop_toBottomOf="@+id/tvComponent"
                app:layout_constraintStart_toEndOf="@+id/ivComponent" android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:id="@+id/tvComponentParamB"
                app:layout_constraintStart_toEndOf="@+id/tvComponentParamA" android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="@+id/tvComponentParamA"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:id="@+id/tvComponentParamC"
                app:layout_constraintStart_toEndOf="@+id/tvComponentParamB" android:layout_marginStart="16dp"
                app:layout_constraintTop_toBottomOf="@+id/tvComponent" android:layout_marginTop="8dp"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvComponentParamD" android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/tvComponentParamA"
                app:layout_constraintStart_toStartOf="@+id/tvComponentParamA" android:layout_marginBottom="8dp"
                app:layout_constraintBottom_toBottomOf="parent"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvComponentParamE" android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/tvComponentParamB"
                app:layout_constraintStart_toEndOf="@+id/tvComponentParamD" android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp" app:layout_constraintBottom_toBottomOf="parent"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvComponentParamF"
                app:layout_constraintStart_toEndOf="@+id/tvComponentParamE" android:layout_marginStart="16dp"
                android:layout_marginTop="8dp" app:layout_constraintTop_toBottomOf="@+id/tvComponentParamC"
                android:layout_marginBottom="8dp" app:layout_constraintBottom_toBottomOf="parent"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvComponentPrice"
                android:layout_marginEnd="16dp"
                app:layout_constraintBottom_toBottomOf="@+id/ivComponent"
                app:layout_constraintTop_toTopOf="@+id/ivComponent"
                app:layout_constraintEnd_toEndOf="parent"/>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>