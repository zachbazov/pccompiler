<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout android:id="@+id/clComponentParent"
                                             android:layout_width="match_parent"
                                             android:layout_height="wrap_content"
                                             tools:context=".activity.Compile"
                                             xmlns:android="http://schemas.android.com/apk/res/android"
                                             xmlns:tools="http://schemas.android.com/tools"
                                             xmlns:app="http://schemas.android.com/apk/res-auto">

    <android.support.constraint.ConstraintLayout android:id="@+id/clComponent"
                                                 android:layout_width="0dp"
                                                 android:layout_height="wrap_content"
                                                 app:layout_constraintTop_toTopOf="parent"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintBottom_toBottomOf="parent"
                                                 app:layout_constraintEnd_toEndOf="parent">

        <ImageView android:id="@+id/ivComponent"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginStart="@dimen/_16dp"
                   android:layout_marginTop="@dimen/_8dp"
                   android:layout_marginBottom="@dimen/_8dp"
                   android:contentDescription="@string/cd_compilation"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toTopOf="parent"
                   app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/tvComponent"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginStart="@dimen/_16dp"
                  android:layout_marginEnd="@dimen/_8dp"
                  android:singleLine="true"
                  app:layout_constraintStart_toEndOf="@+id/ivComponent"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintEnd_toStartOf="@+id/tvComponentPrice"/>

        <TextView android:id="@+id/tvComponentParamA"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="@dimen/_16dp"
                  android:layout_marginTop="@dimen/_8dp"
                  app:layout_constraintTop_toBottomOf="@+id/tvComponent"
                  app:layout_constraintStart_toEndOf="@+id/ivComponent"/>

        <TextView android:id="@+id/tvComponentParamB"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="@dimen/_16dp"
                  app:layout_constraintStart_toEndOf="@+id/tvComponentParamA"
                  app:layout_constraintTop_toTopOf="@+id/tvComponentParamA"/>

        <TextView android:id="@+id/tvComponentParamC"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="@dimen/_16dp"
                  android:layout_marginTop="@dimen/_8dp"
                  app:layout_constraintStart_toEndOf="@+id/tvComponentParamB"
                  app:layout_constraintTop_toBottomOf="@+id/tvComponent"/>

        <TextView android:id="@+id/tvComponentParamD"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginBottom="@dimen/_8dp"
                  app:layout_constraintTop_toBottomOf="@+id/tvComponentParamA"
                  app:layout_constraintStart_toStartOf="@+id/tvComponentParamA"
                  app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/tvComponentParamE"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginStart="@dimen/_16dp"
                  android:layout_marginBottom="@dimen/_8dp"
                  app:layout_constraintTop_toBottomOf="@+id/tvComponentParamB"
                  app:layout_constraintStart_toEndOf="@+id/tvComponentParamD"
                  app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/tvComponentParamF"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="@dimen/_16dp"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginBottom="@dimen/_8dp"
                  app:layout_constraintStart_toEndOf="@+id/tvComponentParamE"
                  app:layout_constraintTop_toBottomOf="@+id/tvComponentParamC"
                  app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/tvComponentPrice"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginEnd="@dimen/_16dp"
                  app:layout_constraintBottom_toBottomOf="@+id/ivComponent"
                  app:layout_constraintTop_toTopOf="@+id/ivComponent"
                  app:layout_constraintEnd_toEndOf="parent"/>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>