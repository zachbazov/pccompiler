<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView android:id="@+id/cvOverviewParent"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="@dimen/_16dp"
                                    android:layout_marginStart="@dimen/_16dp"
                                    app:cardUseCompatPadding="true"
                                    xmlns:android="http://schemas.android.com/apk/res/android"
                                    xmlns:app="http://schemas.android.com/apk/res-auto">

    <android.support.constraint.ConstraintLayout android:id="@+id/clOverview"
                                                 android:layout_width="match_parent"
                                                 android:layout_height="match_parent">

        <ImageView android:id="@+id/ivOverviewClose"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginEnd="@dimen/_8dp"
                   android:contentDescription="@string/cd_close"
                   app:layout_constraintTop_toTopOf="@+id/tvOverview"
                   app:layout_constraintEnd_toEndOf="parent"
                   app:layout_constraintBottom_toBottomOf="@+id/tvOverview"/>

        <ImageView android:id="@+id/ivOverview"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="@dimen/_8dp"
                   android:layout_marginStart="@dimen/_8dp"
                   android:layout_marginEnd="@dimen/_8dp"
                   android:contentDescription="@string/cd_overview"
                   app:layout_constraintTop_toBottomOf="@+id/tvOverviewComponentType"
                   app:layout_constraintEnd_toEndOf="parent"
                   app:layout_constraintStart_toStartOf="parent"/>

        <TextView android:id="@+id/tvOverview"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginStart="@dimen/_8dp"
                  android:layout_marginEnd="@dimen/_8dp"
                  android:textStyle="bold"
                  android:textAllCaps="true"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"/>

        <View android:id="@+id/dvOverview"
              android:layout_width="0dp"
              android:layout_height="1dp"
              android:layout_marginTop="@dimen/_8dp"
              android:layout_marginStart="@dimen/_8dp"
              android:layout_marginEnd="@dimen/_8dp"
              android:background="?android:attr/listDivider"
              app:layout_constraintTop_toBottomOf="@+id/tvOverview"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintEnd_toEndOf="parent"/>

        <TextView android:id="@+id/tvOverviewComponentType"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_16dp"
                  android:layout_marginStart="@dimen/_8dp"
                  android:layout_marginEnd="@dimen/_8dp"
                  app:layout_constraintTop_toBottomOf="@+id/dvOverview"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintStart_toStartOf="parent"/>

        <TextView android:id="@+id/tvOverviewComponent"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginStart="@dimen/_8dp"
                  android:layout_marginEnd="@dimen/_8dp"
                  android:textSize="@dimen/_18sp"
                  android:textAlignment="center"
                  app:layout_constraintTop_toBottomOf="@+id/ivOverview"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout android:id="@+id/llOverviewParent"
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/_8dp"
                      android:layout_marginStart="@dimen/_8dp"
                      android:layout_marginEnd="@dimen/_8dp"
                      android:orientation="horizontal"
                      android:divider="?android:attr/listDivider"
                      android:showDividers="middle"
                      android:background="@drawable/bd_primary"
                      android:baselineAligned="false"
                      app:layout_constraintTop_toBottomOf="@+id/tvOverviewComponent"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout android:id="@+id/llOverviewParameter"
                          android:layout_width="match_parent"
                          android:layout_height="match_parent"
                          android:layout_weight="2"
                          android:orientation="vertical"
                          android:divider="?android:attr/listDivider"
                          android:showDividers="middle">

                <TextView android:id="@+id/tvOverviewParameter"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="center"
                          android:textStyle="bold"
                          android:textAllCaps="false"/>

                <TextView android:id="@+id/tvOverviewParamA"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="center"/>

                <TextView android:id="@+id/tvOverviewParamB"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingBottom="@dimen/_8dp"
                          android:paddingTop="@dimen/_8dp"
                          android:textAlignment="center"/>

                <TextView android:id="@+id/tvOverviewParamC"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingBottom="@dimen/_8dp"
                          android:paddingTop="@dimen/_8dp"
                          android:textAlignment="center"/>

                <TextView android:id="@+id/tvOverviewParamD"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingBottom="@dimen/_8dp"
                          android:paddingTop="@dimen/_8dp"
                          android:textAlignment="center"/>

                <TextView android:id="@+id/tvOverviewParamE"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingBottom="@dimen/_8dp"
                          android:paddingTop="@dimen/_8dp"
                          android:textAlignment="center"/>

                <TextView android:id="@+id/tvOverviewParamF"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingBottom="@dimen/_8dp"
                          android:paddingTop="@dimen/_8dp"
                          android:textAlignment="center"/>

            </LinearLayout>

            <LinearLayout android:id="@+id/llOverviewDescription"
                          android:layout_width="match_parent"
                          android:layout_height="match_parent"
                          android:layout_weight="1"
                          android:orientation="vertical"
                          android:divider="?android:attr/listDivider"
                          android:showDividers="middle">

                <TextView android:id="@+id/tvOverviewDescription"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingBottom="@dimen/_8dp"
                          android:paddingTop="@dimen/_8dp"
                          android:textAlignment="center"
                          android:textStyle="bold"
                          android:textAllCaps="false"/>

                <TextView android:id="@+id/tvOverviewDescA"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingStart="@dimen/_8dp"
                          android:paddingEnd="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="textStart"/>

                <TextView android:id="@+id/tvOverviewDescB"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingStart="@dimen/_8dp"
                          android:paddingEnd="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="textStart"/>

                <TextView android:id="@+id/tvOverviewDescC"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingStart="@dimen/_8dp"
                          android:paddingEnd="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="textStart"/>

                <TextView android:id="@+id/tvOverviewDescD"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingStart="@dimen/_8dp"
                          android:paddingEnd="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="textStart"/>

                <TextView android:id="@+id/tvOverviewDescE"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingStart="@dimen/_8dp"
                          android:paddingEnd="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="textStart"/>

                <TextView android:id="@+id/tvOverviewDescF"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:paddingTop="@dimen/_8dp"
                          android:paddingStart="@dimen/_8dp"
                          android:paddingEnd="@dimen/_8dp"
                          android:paddingBottom="@dimen/_8dp"
                          android:textAlignment="textStart"/>

            </LinearLayout>

        </LinearLayout>

        <TextView android:id="@+id/tvOverviewPrice"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="@dimen/_8dp"
                  android:layout_marginStart="@dimen/_8dp"
                  android:layout_marginEnd="@dimen/_8dp"
                  android:textSize="@dimen/_18sp"
                  app:layout_constraintTop_toBottomOf="@+id/llOverviewParent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"/>

        <ToggleButton android:id="@+id/tbOverview"
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_marginStart="@dimen/_8dp"
                      android:layout_marginEnd="@dimen/_8dp"
                      android:layout_marginBottom="@dimen/_8dp"
                      android:layout_marginTop="@dimen/_8dp"
                      app:layout_constraintTop_toBottomOf="@+id/tvOverviewPrice"
                      app:layout_constraintStart_toStartOf="parent"
                      app:layout_constraintEnd_toEndOf="parent"
                      app:layout_constraintBottom_toBottomOf="parent"/>

    </android.support.constraint.ConstraintLayout>

</android.support.v7.widget.CardView>